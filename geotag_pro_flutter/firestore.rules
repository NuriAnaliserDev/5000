rules_version = '2';

// GeoField Pro — Firestore Security Rules.
//
// Deploy: cd geotag_pro_flutter && firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{db}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(db)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAdmin() {
      return isAuthed()
        && userDocExists()
        && userRole() in ['admin', 'geologist_senior'];
    }

    match /users/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if isAuthed() && request.auth.uid == uid;

      match /stations/{stationId} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }

      match /tracks/{trackId} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }
    }

    match /presence/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    match /emergency_signals/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.senderUid == request.auth.uid;
      allow update: if isAuthed()
                    && resource.data.senderUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Global chegaralar (DXF/KML importidan keladigan poligonlar).
    // Har qanday avtorizatsiyalangan foydalanuvchi yangisini qo‘sha oladi
    // va o‘zgartirishi mumkin. O‘chirish esa — tegishli yozuv egasi
    // yoki admin tomonidan amalga oshiriladi.
    match /global_boundaries/{doc} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isAuthed();
    }

    match /global_lines/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Geologik chiziqlar — har bir avtorizatsiyalangan foydalanuvchi
    // o‘qishi va yozishi mumkin (jamoaviy linework).
    match /geological_lines/{doc} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isAuthed();
    }

    // Xarita ustiga qo‘yiladigan strike/dip annotatsiyalari.
    match /map_structure_annotations/{doc} {
      allow read: if isAuthed();
      allow create, update: if isAuthed();
      allow delete: if isAuthed();
    }

    // Ommaviy e'lonlar / bildirishnomalar. Yozish — faqat admin
    // konsoldan yoki cloud function orqali.
    match /geofield_broadcasts/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Chat xabarlari — foydalanuvchining o‘ziga tegishli
    match /chat_messages/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthed()
                    && resource.data.senderId == request.auth.uid;
    }

    // Kon hisobotlari: yaratish faqat o‘z UID bilan; o‘qish — dashboard (autentifikatsiyadan o‘tganlar).
    match /daily_mine_reports/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.authorUid == request.auth.uid
        && 'reportType' in request.resource.data
        && 'authorName' in request.resource.data
        && 'status' in request.resource.data
        && 'parsedData' in request.resource.data;
      allow update: if isAuthed();
      // Rad etish / tozalash: kichik jamoa; kerak bo‘lsa keyinroq faqat muallif yoki admin qilib toraytirasiz.
      allow delete: if isAuthed();
    }

    // Guruh hujjati — faqat konsoldan; ilova faqat messages yozadi.
    match /chat_groups/{groupId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthed()
          && resource.data.senderId == request.auth.uid;
      }
    }

    match /groups/{groupId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthed()
          && resource.data.senderId == request.auth.uid;
      }
    }

    match /ai_quota_overrides/{uid} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
  }
}
