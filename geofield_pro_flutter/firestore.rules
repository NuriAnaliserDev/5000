rules_version = '2';

// GeoField Pro — Firestore Security Rules.
//
// Deploy: cd geofield_pro_flutter && firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{db}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function userDocExists() {
      return exists(/databases/$(db)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDocExists()
        ? get(/databases/$(db)/documents/users/$(request.auth.uid)).data.role
        : '';
    }

    function isAdmin() {
      return isAuthed()
        && userDocExists()
        && userRole() in ['admin', 'geologist_senior'];
    }

    match /users/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if isAuthed() && request.auth.uid == uid;

      match /stations/{stationId} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }

      match /tracks/{trackId} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }
    }

    match /presence/{uid} {
      allow read: if isAuthed();
      allow write: if isAuthed() && request.auth.uid == uid;
    }

    match /emergency_signals/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.senderUid == request.auth.uid;
      allow update: if isAuthed()
                    && resource.data.senderUid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Global chegaralar — createdByUid yozuv egasi yoki admin tahrirlaydi/o‘chiradi.
    // createdByUid yo‘q (legacy) hujjatlar: faqat admin.
    match /global_boundaries/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isAuthed() && (
        isAdmin()
        || (
          'createdByUid' in resource.data
          && resource.data.createdByUid == request.auth.uid
        )
      );
      allow delete: if isAuthed() && (
        isAdmin()
        || (
          'createdByUid' in resource.data
          && resource.data.createdByUid == request.auth.uid
        )
      );
    }

    match /global_lines/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Geologik chiziqlar — ownerUid egasi yoki admin; legacy: faqat admin.
    match /geological_lines/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthed() && (
        isAdmin()
        || (
          'ownerUid' in resource.data
          && resource.data.ownerUid == request.auth.uid
        )
      );
      allow delete: if isAuthed() && (
        isAdmin()
        || (
          'ownerUid' in resource.data
          && resource.data.ownerUid == request.auth.uid
        )
      );
    }

    // Strike/dip annotatsiyalari — ownerUid egasi yoki admin; legacy: faqat admin.
    match /map_structure_annotations/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isAuthed() && (
        isAdmin()
        || (
          'ownerUid' in resource.data
          && resource.data.ownerUid == request.auth.uid
        )
      );
      allow delete: if isAuthed() && (
        isAdmin()
        || (
          'ownerUid' in resource.data
          && resource.data.ownerUid == request.auth.uid
        )
      );
    }

    // Ommaviy e'lonlar / bildirishnomalar. Yozish — faqat admin
    // konsoldan yoki cloud function orqali.
    match /geofield_broadcasts/{doc} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Chat xabarlari — foydalanuvchining o‘ziga tegishli
    match /chat_messages/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthed()
                    && resource.data.senderId == request.auth.uid;
    }

    // Kon hisobotlari: tasdiqlash/rad — admin; muallif faqat pending holatda tahrir/o‘chirish.
    // authorUid yo‘q legacy: update/delete faqat admin.
    match /daily_mine_reports/{doc} {
      allow read: if isAuthed();
      allow create: if isAuthed()
        && request.resource.data.authorUid == request.auth.uid
        && 'reportType' in request.resource.data
        && 'authorName' in request.resource.data
        && 'status' in request.resource.data
        && 'parsedData' in request.resource.data;
      allow update: if isAuthed() && (
        isAdmin()
        || (
          'authorUid' in resource.data
          && resource.data.authorUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.authorUid == resource.data.authorUid
          && request.resource.data.status == 'pending'
        )
      );
      allow delete: if isAuthed() && (
        isAdmin()
        || (
          'authorUid' in resource.data
          && resource.data.authorUid == request.auth.uid
          && resource.data.status == 'pending'
        )
      );
    }

    // Guruh hujjati — faqat konsoldan; ilova faqat messages yozadi.
    match /chat_groups/{groupId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthed()
          && resource.data.senderId == request.auth.uid;
      }
    }

    match /groups/{groupId} {
      allow read: if isAuthed();
      allow create, update, delete: if false;

      match /messages/{msgId} {
        allow read: if isAuthed();
        allow create: if isAuthed()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAuthed()
          && resource.data.senderId == request.auth.uid;
      }
    }

    match /ai_quota_overrides/{uid} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }
  }
}
